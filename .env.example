# Supabase - Lấy từ https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Chỉ dùng trên server (API routes), KHÔNG dùng ở client
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Apps Script Web App URL (ghi lái xe ngược lại vào Google Sheet)
# 1 script duy nhất xử lý cả B2B, GT và MT
# Tạo tại: script.google.com → New project (standalone) → dán write-lai-xe.gs → Deploy
APPS_SCRIPT_WRITE_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
